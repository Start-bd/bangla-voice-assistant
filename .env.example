# Bangla Voice Assistant Backend Environment Variables

# Soniox API Key for Bengali Speech-to-Text
# Get your key at: https://soniox.com/speech-to-text/bengali
SONIOX_API_KEY=your_soniox_api_key_here

# OpenAI API Key for Translation and Intent Classification
# Get your key at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Server Port (optional, defaults to 3000)
PORT=3000
